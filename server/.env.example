# Copy to .env (gitignored) and fill in. No real keys are committed to the repo.

# --- Tavus CVI (https://tavusapi.com) — live video intake ---
TAVUS_API_KEY=
TAVUS_PERSONA_ID=               # created once by: npm run setup:persona
TAVUS_REPLICA_ID=r90bbd427f71   # stock replica — no recording needed
PUBLIC_URL=                     # optional https tunnel for Tavus webhooks (transcript is also fetched on-demand)

# --- AI intake report (OpenAI) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Email delivery (Resend — resend.com) ---
RESEND_API_KEY=
INTAKE_EMAIL_TO=                # report recipient (your team inbox)
INTAKE_EMAIL_FROM=AppHatchery Intake <onboarding@resend.dev>

# --- Optional backends (Notion / Airtable) ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

PORT=8000
